@startuml SSD_ListVaccines
title SSD: UC5 - List Vaccines Stock

actor "Center Administrator" as Admin
participant ":System" as System

autonumber
activate Admin
Admin -> System: requests a list of all vaccines in the system
activate System

alt no vaccines in stock
    System --> Admin: displays "No inventory found" message
else vaccines found
     System --> Admin: displays vaccines grouped by type and sorted by brand (with details)
end

deactivate System
deactivate Admin
@enduml